# ============================================
# Pardah E-commerce Platform - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ============================================
# Firebase Configuration (Required)
# ============================================
# Get these from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: For server-side Firebase Admin operations
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# OR use service account JSON file path
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================
# Site Configuration (Optional)
# ============================================
# Your site URL (used for email links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Alternative base URL
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# VERCEL_URL is automatically set by Vercel (don't set manually)

# ============================================
# Stripe Payment Gateway (Optional)
# ============================================
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# For Firebase Functions (set in Firebase Console > Functions > Configuration)
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ============================================
# PayPal Payment Gateway (Optional)
# ============================================
# Get from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox
# Use 'production' for live payments

# ============================================
# Razorpay Payment Gateway (Optional)
# ============================================
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================
# Paystack Payment Gateway (Optional)
# ============================================
# Get from: https://dashboard.paystack.com/#/settings/developer
# Configure in Admin Panel > Settings > Payment Gateways

# ============================================
# Flutterwave Payment Gateway (Optional)
# ============================================
# Get from: https://dashboard.flutterwave.com/settings/apis
# Configure in Admin Panel > Settings > Payment Gateways

# ============================================
# Google Services (Optional)
# ============================================
# Google Maps API Key (for Store Locator feature)
# Get from: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth Client ID (for Backup/Restore feature)
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ============================================
# Dropbox Integration (Optional)
# ============================================
# For Backup/Restore feature
# Get from: https://www.dropbox.com/developers/apps
NEXT_PUBLIC_DROPBOX_APP_KEY=your_dropbox_app_key_here

# ============================================
# reCAPTCHA (Optional)
# ============================================
# Configure in Admin Panel > Settings
# Get from: https://www.google.com/recaptcha/admin

# ============================================
# SMTP Email Configuration (Optional)
# ============================================
# Configure in Admin Panel > Settings > Email Notifications
# Or use environment variables if you prefer:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Your Store Name

# ============================================
# Notes
# ============================================
# 1. All NEXT_PUBLIC_* variables are exposed to the browser
# 2. Never commit .env.local or .env files to version control
# 3. For production, set environment variables in your hosting platform:
#    - Vercel: Project Settings > Environment Variables
#    - Firebase: Functions > Configuration > Environment Variables
#    - Other platforms: Check their documentation
# 4. Payment gateway keys can also be configured in Admin Panel > Settings > Payment Gateways
# 5. SMTP settings can be configured in Admin Panel > Settings > Email Notifications
